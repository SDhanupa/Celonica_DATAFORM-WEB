# ─── Large data dumps (never commit) ───────────────────
*.sql
*.dump
celonica_dump*
celonica_fresh*
celonica_data*
celonica_unique*
celonica_schema*

# ─── db_parts/ IS committed (split compressed parts for git) ─
!db_parts/
!db_parts/**

# ─── Node / NPM ─────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env.local

# ─── Laravel ────────────────────────────────────────────
backend/vendor/
backend/.env
backend/storage/logs/
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/
backend/bootstrap/cache/

# ─── JSON export scratch files (re-generated by scripts) ─
backend/rooms_data.json
backend/roof_data.json
backend/religion_data.json
backend/household_head_data.json

# ─── OS / Editor ─────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Large raw Excel / CSV source files ──────────────────
*.xlsx
*.csv
Gemini_Generated_Image*
නිර්මානය.png
